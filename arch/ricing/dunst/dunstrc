# Dunst Configuration - Jam Dark (LightDM Colors)
# Matches the warm, vintage aesthetic from LightDM greeter
# Color scheme: Dark grays with warm cream accents

[global]
    monitor = 0
    follow = keyboard
    width = (250, 500)
    height = (0, 750)
    offset = (17, 26)
    padding = 12
    horizontal_padding = 14
    gap_size = 8
    transparency = 8
    frame_width = 1
    frame_color = "#fff7c033"  # Warm cream with 20% opacity
    font = JetBrains Mono 11
    corner_radius = 12
    min_icon_size = 32
    max_icon_size = 32
    format = "<b>%s</b>\n%b"

# Low urgency notifications
[urgency_low]
    foreground = "#fff7c0"      # Warm cream text
    background = "#3b3e3fea"    # Primary background (92% opacity)
    frame_color = "#fff7c01a"   # Subtle border (10% opacity)
    timeout = 3

# Normal urgency notifications
[urgency_normal]
    foreground = "#fff7c0"      # Warm cream text
    background = "#3b3e3fea"    # Primary background (92% opacity)
    frame_color = "#fff7c073"   # Medium border (45% opacity)
    timeout = 5

# Critical urgency notifications
[urgency_critical]
    foreground = "#fff7c0"      # Warm cream text
    background = "#20272e"      # Darker background for emphasis
    frame_color = "#fff7c0"     # Full opacity border
    timeout = 15
